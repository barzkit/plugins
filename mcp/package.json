{
  "name": "@barzkit/mcp",
  "version": "0.1.0",
  "type": "module",
  "description": "MCP Server for self-custody AI agent wallets — 11 tools for Claude Desktop, Cursor, Windsurf, and VS Code Copilot",
  "main": "./dist/server.js",
  "types": "./dist/server.d.ts",
  "bin": {
    "barzkit-mcp": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai-agents",
    "barzkit",
    "web3",
    "self-custody",
    "erc-4337",
    "smart-accounts",
    "claude-desktop",
    "cursor"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/barzkit/plugins",
    "directory": "mcp"
  },
  "dependencies": {
    "@barzkit/sdk": "^0.2.0",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
