{
  "name": "@barzkit/elizaos",
  "version": "0.1.0",
  "type": "module",
  "description": "BarzKit plugin for ElizaOS — self-custody AI agent wallets with send, swap, lend, freeze, and x402 payments",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "elizaos",
    "eliza",
    "ai-agents",
    "barzkit",
    "web3",
    "self-custody",
    "erc-4337",
    "smart-accounts",
    "plugin"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/barzkit/plugins",
    "directory": "elizaos"
  },
  "dependencies": {
    "@barzkit/sdk": "^0.1.4"
  },
  "peerDependencies": {
    "@elizaos/core": ">=0.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
